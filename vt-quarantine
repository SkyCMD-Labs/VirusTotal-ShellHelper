#!/usr/bin/env bash
#
# vt-quarantine - Manage quarantined files from VirusTotal scans
#
# Usage: vt-quarantine <command> [args]
#
# Commands:
#   list              List all quarantined files
#   restore <file>    Restore a file from quarantine (use with caution!)
#   delete <file>     Permanently delete a quarantined file
#   open              Open quarantine directory in file manager
#   path              Print quarantine directory path
#

set -o pipefail

VERSION="1.0.0"

# Source action functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/vt-actions.sh" ]]; then
    source "$SCRIPT_DIR/vt-actions.sh"
elif [[ -f "$HOME/.local/bin/vt-actions.sh" ]]; then
    source "$HOME/.local/bin/vt-actions.sh"
else
    echo "Error: vt-actions.sh not found" >&2
    exit 1
fi

usage() {
    cat <<EOF
vt-quarantine v${VERSION} - Manage quarantined files

Usage: vt-quarantine <command> [args]

Commands:
  list              List all quarantined files
  restore <file>    Restore a file from quarantine (DANGEROUS!)
  delete <file>     Permanently delete a quarantined file
  open              Open quarantine directory in file manager
  path              Print quarantine directory path
  -h, --help        Show this help message

Examples:
  vt-quarantine list
  vt-quarantine restore "$QUARANTINE_DIR/suspicious.exe"
  vt-quarantine delete "$QUARANTINE_DIR/malware.bin"
  vt-quarantine open
EOF
}

cmd_list() {
    list_quarantine
}

cmd_restore() {
    local file="$1"
    
    if [[ -z "$file" ]]; then
        echo "Error: No file specified" >&2
        echo "Usage: vt-quarantine restore <file>" >&2
        exit 1
    fi
    
    if [[ ! -f "$file" ]]; then
        echo "Error: File not found: $file" >&2
        exit 1
    fi
    
    echo "⚠️  WARNING: You are about to restore a potentially malicious file!"
    echo "File: $file"
    echo ""
    read -p "Are you sure you want to restore this file? (type 'yes' to confirm): " confirm
    
    if [[ "$confirm" != "yes" ]]; then
        echo "Restore cancelled"
        exit 0
    fi
    
    local restored
    restored=$(restore_from_quarantine "$file")
    
    if [[ -n "$restored" ]]; then
        echo "✓ File restored to: $restored"
        echo "⚠️  Please scan this file again before executing!"
    else
        echo "✗ Failed to restore file" >&2
        exit 1
    fi
}

cmd_delete() {
    local file="$1"
    
    if [[ -z "$file" ]]; then
        echo "Error: No file specified" >&2
        echo "Usage: vt-quarantine delete <file>" >&2
        exit 1
    fi
    
    if [[ ! -f "$file" ]]; then
        echo "Error: File not found: $file" >&2
        exit 1
    fi
    
    if [[ "$file" != "$QUARANTINE_DIR"/* ]]; then
        echo "Error: File is not in quarantine directory" >&2
        exit 1
    fi
    
    echo "⚠️  WARNING: This will permanently delete the file!"
    echo "File: $file"
    echo ""
    read -p "Are you sure you want to delete this file? (type 'yes' to confirm): " confirm
    
    if [[ "$confirm" != "yes" ]]; then
        echo "Delete cancelled"
        exit 0
    fi
    
    if rm -f "$file"; then
        echo "✓ File permanently deleted"
    else
        echo "✗ Failed to delete file" >&2
        exit 1
    fi
}

cmd_open() {
    if [[ ! -d "$QUARANTINE_DIR" ]]; then
        mkdir -p "$QUARANTINE_DIR"
        chmod 700 "$QUARANTINE_DIR"
    fi
    
    if command -v xdg-open &>/dev/null; then
        xdg-open "$QUARANTINE_DIR" 2>/dev/null &
        echo "Opening quarantine directory: $QUARANTINE_DIR"
    else
        echo "Error: xdg-open not found" >&2
        echo "Quarantine directory: $QUARANTINE_DIR" >&2
        exit 1
    fi
}

cmd_path() {
    echo "$QUARANTINE_DIR"
}

main() {
    local command="$1"
    shift
    
    case "$command" in
        list)
            cmd_list "$@"
            ;;
        restore)
            cmd_restore "$@"
            ;;
        delete)
            cmd_delete "$@"
            ;;
        open)
            cmd_open "$@"
            ;;
        path)
            cmd_path "$@"
            ;;
        -h|--help|"")
            usage
            exit 0
            ;;
        *)
            echo "Error: Unknown command: $command" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
